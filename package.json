{
  "name": "crypto-tracker",
  "version": "2.5.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --watch server/index.js\"",
    "build": "tsc --noEmit && vite build && node -e \"fs.writeFileSync('.last-build',Date.now().toString())\"",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run type-check",
    "security": "npm audit --audit-level=high",
    "restart:pm2": "npm run build && cd .. && pm2 restart crypto-tracker",
    "sast": "semgrep scan --config auto --error --quiet",
    "secrets": "betterleaks git . -v",
    "licenses": "license-checker --production --failOn 'GPL-2.0;GPL-3.0;AGPL-1.0;AGPL-3.0' --summary",
    "licenses:file": "license-checker --production > THIRD-PARTY-LICENSES.txt",
    "deps:check": "node ../build-policy/scripts/check-allowlist.js .",
    "deps:verify": "node ../build-policy/scripts/verify-package.js",
    "review": "coderabbit review --agent",
    "prepare": "husky",
    "lint:html": "html-validate *.html",
    "validate": "npm run lint && npm run lint:html && npm run format:check && npm run type-check",
    "test:smoke": "node -e \"fetch('http://localhost:3007/api/market/overview').then(r=>{if(!r.ok)throw new Error(r.status);console.log('smoke ok')}).catch(e=>{console.error('smoke fail:',e.message);process.exit(1)})\"",
    "quality": "npm run validate && npm run sast && npm run security && npm run secrets && npm run licenses && npm run deps:check && npm run review"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.12.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.1",
    "html-validate": "^11.5.6",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5"
  }
}
